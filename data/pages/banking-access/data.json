  "meta": {
    "title": "Access to Formal Banking",
    "subtitle": "% of adults with a bank account and PMJDY penetration by state",
    "source": "NFHS-5 2019–21, IIPS/MoHFW; RBI FI Index; PMJDY Dashboard, Ministry of Finance",
